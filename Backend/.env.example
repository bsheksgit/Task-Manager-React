# Database Connection (PostgreSQL)
# Local development: postgresql://postgres:postgres@localhost:5432/taskmanager
# Docker Compose:   postgresql://postgres:postgres@postgres:5432/taskmanager
# Render:           Set via Render Dashboard (auto-generated)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/taskmanager

# JWT Configuration
JWT_SECRET_KEY="your-secret-key-change-in-production"
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10

# CORS Origins (comma-separated)
# Local: http://localhost:5173,http://localhost:3000,http://localhost
# Production: https://your-app.vercel.app
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost

# Application Settings
DEBUG=True
